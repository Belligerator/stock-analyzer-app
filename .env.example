# Payload
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Neon Postgres — pooled connection string (z Neon dashboardu)
DATABASE_URL=postgresql://user:password@host-pooler.neon.tech/dbname?sslmode=require&channel_binding=require

# Anthropic (for AI notes enrichment)
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret pro GH Actions cron triggers — libovolný náhodný string
CRON_SECRET=change-me-to-a-long-random-string

# ---- AI model config (volitelné, defaulty níže) ----

# Stage 1: trigger detection (bez web search, batch)
# MODEL_TRIGGER=claude-haiku-4-5

# Stage 2: deep analysis routed by priority
# MODEL_ANALYZE_NORMAL=claude-sonnet-4-6
# MODEL_ANALYZE_HIGH=claude-opus-4-7

# Web search / fetch limity per priority (0 = disabled)
# WEB_SEARCH_MAX_NORMAL=2
# WEB_SEARCH_MAX_HIGH=4
# WEB_FETCH_MAX_NORMAL=1
# WEB_FETCH_MAX_HIGH=3
# WEB_FETCH_CONTENT_TOKENS_NORMAL=5000
# WEB_FETCH_CONTENT_TOKENS_HIGH=10000

# ---- Yahoo Finance data limity (volitelné, defaulty níže) ----
# Kolik news/reports/upgrades se stahuje per ticker při daily refresh.
# Víc = lepší kontext pro AI, ale větší DB + více tokenů v triage promptu.
# YAHOO_NEWS_COUNT=5
# YAHOO_REPORTS_COUNT=3
# YAHOO_UPGRADES_COUNT=5
